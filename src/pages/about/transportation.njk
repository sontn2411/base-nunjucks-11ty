<div class="max-w-7xl mx-auto px-6 py-24 space-y-32 overflow-hidden">
  
  <!-- Section 1: Xe buýt -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    <div class="lg:col-span-7 group relative reveal fade-right">
      <div class="absolute -inset-4 border border-champa/30 transform translate-x-4 translate-y-4 group-hover:translate-x-2 group-hover:translate-y-2 transition-transform duration-500"></div>
      <div class="relative overflow-hidden h-[450px]">
        <img alt="Nha Trang Shuttle" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="{{ services.bus.image }}">
      </div>
    </div>
    <div class="lg:col-span-5 flex flex-col justify-center reveal fade-left delay-200">
      <span class="text-primary font-bold tracking-[0.2em] uppercase text-sm mb-4">{{ services.bus.tag }}</span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6 font-playfair">{{ services.bus.title }}</h2>
      <div class="space-y-6 text-slate-600 leading-relaxed font-body font-light">
        <p>{{ services.bus.desc }}</p>
        <div class="p-6 bg-primary/5 border-l-4 border-primary">
          <div class="flex items-center justify-between mb-2">
            <span class="font-bold text-slate-900">Giá vé ưu đãi</span>
            <span class="text-primary font-bold text-xl">{{ services.bus.price }}</span>
          </div>
          <p class="text-sm">{{ services.bus.price_note }}</p>
        </div>
        <ul class="space-y-3 pt-4">
          {% for item in services.bus.details %}
          <li class="flex items-center gap-3">
            {{icon(item.icon, 'text-primary text-xl flex-shrink-0')}}
            <span>{{ item.text }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>

  <!-- Section 2: Đưa đón Sân bay -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    <div class="lg:col-span-5 order-2 lg:order-1 flex flex-col justify-center reveal fade-right">
      <span class="text-champa font-bold tracking-[0.2em] uppercase text-sm mb-4">{{ services.airport.tag }}</span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6 font-playfair">{{ services.airport.title }}</h2>
      <div class="space-y-6 text-slate-600 leading-relaxed font-body font-light">
        <p>{{ services.airport.desc }}</p>
        <div class="p-6 bg-champa/5 border-l-4 border-champa">
          <div class="flex items-center justify-between mb-2">
            <span class="font-bold text-slate-900">Dịch vụ trọn gói</span>
            <span class="text-primary font-bold text-xl">{{ services.airport.price }}</span>
          </div>
          <p class="text-sm">{{ services.airport.price_note }}</p>
        </div>
        <div class="grid grid-cols-2 gap-4 pt-4">
          {% for item in services.airport.highlights %}
          <div class="flex flex-col gap-1 p-4 bg-background-light border border-slate-200">
            {{icon(item.icon, 'text-primary text-xl mb-1')}}
            <span class="font-bold text-slate-900">{{ item.title }}</span>
            <span class="text-xs italic">{{ item.desc }}</span>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
    <div class="lg:col-span-7 order-1 lg:order-2 group relative reveal fade-left delay-200">
      <div class="absolute -inset-4 border border-primary/20 transform -translate-x-4 translate-y-4 group-hover:-translate-x-2 group-hover:translate-y-2 transition-transform duration-500"></div>
      <div class="relative overflow-hidden h-[450px]">
        <img alt="Airport Transfer Service" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="{{ services.airport.image }}">
      </div>
    </div>
  </div>

  <!-- Section 3: Cho thuê xe -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    <div class="lg:col-span-7 group relative reveal fade-right">
      <div class="absolute -inset-4 border border-champa/30 transform translate-x-4 translate-y-4 group-hover:translate-x-2 group-hover:translate-y-2 transition-transform duration-500"></div>
      <div class="relative overflow-hidden h-[450px]">
        <img alt="Car Rental Service" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" src="{{ services.rental.image }}">
      </div>
    </div>
    <div class="lg:col-span-5 flex flex-col justify-center reveal fade-left delay-200">
      <span class="text-primary font-bold tracking-[0.2em] uppercase text-sm mb-4">{{ services.rental.tag }}</span>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6 font-playfair">{{ services.rental.title }}</h2>
      <div class="space-y-6 text-slate-600 leading-relaxed font-body font-light">
        <p>{{ services.rental.desc }}</p>
        <div class="flex items-start gap-4 p-4 bg-champa/5 border border-champa/10">
          {{icon('info', 'text-champa pt-1 w-10 h-10 flex-shrink-0')}}
          <div class="text-sm italic">Quý khách vui lòng mang theo Giấy phép lái xe hợp lệ. Bảo hiểm thân vỏ đã được bao gồm trong phí thuê xe.</div>
        </div>
        <ul class="space-y-4 pt-4">
          {% for item in services.rental.details %}
          <li class="flex items-start gap-4">
            <div class="bg-primary/10 p-2 rounded-full flex-shrink-0">
              {{icon(item.icon, 'text-primary text-xl')}}
            </div>
            <div>
              <h4 class="font-bold text-slate-900">{{ item.title }}</h4>
              <p class="text-sm">{{ item.desc }}</p>
            </div>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>

</div>
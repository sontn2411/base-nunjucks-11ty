{% from 'components/icons.njk' import icon %}

{# ── Hero Section ── #}
<section class="relative h-screen min-h-[600px] flex items-center justify-center pt-20">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-linear-to-b from-background-dark/60 via-background-dark/20 to-background-light z-10"></div>
    <div class="w-full h-full bg-cover bg-center" data-alt="Luxury resort with Champa architecture and swimming pool"
      style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAvLItJv7JJxb8T37kUOmEADsudWlbAWLLi73fTUbSmzudX4EGY-wePCLt70jwp3bAOvHHKCRHm63pi6Xvf_BmEEr_BTOTkKM-klw3lxQi4b0iJiHruXE-2K9EBZrcG5gQ0vTaSfTVtGLvz9hEg5kdTzqJ-82VMu3j0lIUcYzNLX5O-tsGcrYIylb8g-NELOf9PWjd6rwh1ah54L2yTBRsSLrfiiir672UqmjNjrlpUipsL36v1ulllg6c17ISWolTMyML7byy5jFY')">
    </div>
  </div>
  <div class="relative z-20 text-center px-4 max-w-4xl mx-auto">
    <span class="text-primary font-semibold tracking-[0.4em] uppercase mb-4 block text-xs reveal font-body">Tiện Ích Cao
      Cấp</span>
    <h1 class="text-white text-5xl md:text-7xl lg:text-8xl font-bold mb-6 leading-tight drop-shadow-2xl reveal delay-100 font-playfair">
      Dịch Vụ <span class="text-primary drop-shadow-sm font-playfair">Đưa Đón</span>
    </h1>
    <p class="text-white/90 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed mb-10 reveal delay-200 font-body">
      Trải nghiệm sự thuận tiện tuyệt đối với dịch vụ đưa đón chuyên nghiệp, thân thiện môi trường tại Mövenpick Resort
      Cam Ranh.
    </p>
  </div>
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 animate-bounce">
    {{icon('keyboard_double_arrow_down', 'text-white/50 w-16 h-16')}}
  </div>
</section>

{# --- Dữ liệu tĩnh dùng chung --- #}

<nav class="fixed top-0 z-50 w-full transition-all duration-500 ">

  <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-between p-4">
    <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
      <img src="/assets/images/logo.webp" class="h-12 md:h-16 w-auto object-cover " alt="Logo" />
    </a>
    <div class="flex space-x-3 md:order-2 md:space-x-0 rtl:space-x-reverse">
      <button id="mobile-menu-open" type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg p-2 text-sm text-white hover:bg-white/10 focus:outline-none md:hidden transition-colors"
        aria-controls="mobile-sheet" aria-expanded="false">
        <span class="sr-only">Open main menu</span>
        <svg class="h-6 w-6" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M1 1h15M1 7h15M1 13h15" />
        </svg>
      </button>
    </div>

    {% macro renderNav(items, isSubmenu = false) %}
    <ul
      class="dropdown-menu absolute transition-all duration-300 {% if isSubmenu %}submenu{% else %}top-full left-0 origin-top{% endif %}"
      role="menu" aria-hidden="true">
      {% for item in items %}
      <li class="group relative" role="none">
        {% if item.children %}
        <button
          class="nav-link w-full text-left flex items-center justify-between px-4 py-2.5 text-sm text-gray-800 hover:text-primary outline-none focus:outline-none"
          aria-haspopup="true" aria-expanded="false" role="menuitem">
          <span>{{ item.label }}</span>
          <svg class="h-3.5 w-3.5 transition-transform duration-300 group-hover:-rotate-90"
            xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd"
              d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
              clip-rule="evenodd" />
          </svg>
        </button>
        {{ renderNav(item.children, true) }}
        {% else %}
        <a href="{{ item.url }}" class="nav-link block px-4 py-2.5 text-sm text-gray-800 hover:text-primary"
          role="menuitem">{{ item.label }}</a>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
    {% endmacro %}

    <!-- Desktop Menu -->
    <div class="hidden w-full items-center justify-between md:order-1 md:flex md:w-auto" id="navbar-sticky">
      <ul class="flex flex-col md:flex-row md:space-x-10 font-medium">
        {% for item in navigation %}
        <li class="group relative">
          {% if item.children %}
          <button
            class="nav-link flex items-center justify-between py-2 text-white hover:text-white/80 transition-colors duration-200"
            aria-haspopup="true" aria-expanded="false">
            <a href="{{ item.url }}"><span class="text-[15px] uppercase tracking-wider font-semibold">{{ item.label
                }}</span></a>
            <svg class="w-3 h-3 ms-2 transition-transform duration-300 group-hover:rotate-180" aria-hidden="true"
              xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="m1 1 4 4 4-4" />
            </svg>
          </button>
          {{ renderNav(item.children) }}
          {% else %}
          <a href="{{ item.url }}"
            class="nav-link block py-2 text-white hover:text-white/80 transition-colors duration-200" {% if
            page.url==item.url %}aria-current="page" {% endif %}>
            <span class="text-[15px] uppercase tracking-wider font-semibold">{{ item.label }}</span>
          </a>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</nav>

<!-- Mobile Overlay -->
<div id="mobile-overlay"
  class="fixed inset-0 z-60 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 md:hidden">
</div>

<!-- Mobile Side Menu (Sheet) -->
<div id="mobile-sheet"
  class="fixed top-0 right-0 z-70 h-full w-[85%] max-w-[320px] bg-background-light translate-x-full transition-transform duration-400 ease-out md:hidden shadow-2xl flex flex-col">
  <div class="p-6 flex items-center justify-between border-b border-gray-100">
    <img src="/assets/images/logo.webp" class="h-10 w-auto object-cover " alt="Logo" />
    <button id="mobile-menu-close" type="button" class="p-2 text-gray-500 hover:text-primary transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="flex-1 overflow-y-auto py-8 px-6">
    <nav class="space-y-6">
      {% macro renderMobileNav(items, depth = 0) %}
      {% for item in items %}
      <div class="space-y-1">
        {% if item.children %}
        <button type="button"
          class="mobile-submenu-toggle flex w-full items-center justify-between py-3 {% if depth == 0 %}text-xl font-bold text-slate-900 border-b border-gray-100{% else %}text-lg font-medium text-slate-800 pl-4{% endif %} hover:text-primary transition-colors group"
          aria-expanded="false">
          <span>{{ item.label }}</span>
          <svg class="h-5 w-5 transition-transform duration-300 group-[.is-open]:rotate-180"
            xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd" />
          </svg>
        </button>
        <div class="mobile-submenu hidden overflow-hidden transition-all duration-300">
          <div class="py-2 space-y-2">
            {{ renderMobileNav(item.children, depth + 1) }}
          </div>
        </div>
        {% else %}
        <a href="{{ item.url }}"
          class="block py-3 {% if depth == 0 %}text-xl font-bold text-slate-900 border-b border-gray-100{% else %}text-lg font-medium text-slate-800 pl-4{% endif %} hover:text-primary transition-all duration-200">
          {{ item.label }}
        </a>
        {% endif %}
      </div>
      {% endfor %}
      {% endmacro %}

      {{ renderMobileNav(navigation) }}
    </nav>
  </div>

  <div class="p-8 border-t border-gray-100 bg-gray-50/50">
    <button class="w-full bg-primary text-white py-4 font-bold tracking-wide shadow-lg shadow-primary/20">
      Đặt phòng ngay
    </button>
  </div>
</div>
    <div class="space-y-32 pb-20">
      {% for service in services %}
      <section
        class="group flex flex-col {{ 'lg:flex-row-reverse' if loop.index0 % 2 !== 0 else 'lg:flex-row' }} items-center gap-12 lg:gap-24">
        <div class="flex-1 w-full relative reveal {{ 'reveal-right' if loop.index0 % 2 !== 0 else 'reveal-left' }}">
          <div
            class="absolute -inset-4 border border-primary/20  z-10 group-hover:scale-105 transition-transform duration-500">
          </div>
          <div class="aspect-[4/3]  overflow-hidden shadow-2xl">
            <img alt="{{ service.imageAlt }}"
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
              data-alt="{{ service.imageDataAlt }}" src="{{ service.image }}">
          </div>
        </div>
        <div class="flex-1 space-y-6 reveal {{ 'reveal-left' if loop.index0 % 2 !== 0 else 'reveal-right' }}">
          <div class="inline-flex items-center gap-2 text-primary">
            {{ icon(service.icon , 'text-primary') }}
            <span class="text-sm font-bold tracking-widest uppercase">{{ service.tag }}</span>
          </div>
          <h3 class=" font-display text-3xl md:text-4xl {{ 'text-primary' if loop.index0 > 0 }} leading-tight">{{
            service.title }}</h3>
          <p class="text-slate-600 text-lg leading-relaxed">
            {{ service.description }}
          </p>

          {% if service.features %}
          <ul class="space-y-3 pb-4">
            {% for feature in service.features %}
            <li class="flex items-center gap-3 text-slate-700">
              {{ icon(service.featureIcon if service.featureIcon else 'check-circle' , 'text-primary') }}
              {{ feature }}
            </li>
            {% endfor %}
          </ul>
          {% endif %}

          {% if service.highlights %}
          <div class="grid grid-cols-2 gap-4 pb-4">
            {% for highlight in service.highlights %}
            <div class="p-4 bg-primary/5  border border-primary/10">
              <p class="font-bold text-primary">{{ highlight.label }}</p>
              <p class="text-xs text-slate-500">{{ highlight.sub }}</p>
            </div>
            {% endfor %}
          </div>
          {% endif %}

          {% if service.badges %}
          <div class="flex flex-wrap gap-4 pb-4">
            {% for badge in service.badges %}
            <span class="px-4 py-2 bg-primary/5 text-primary rounded-full text-xs font-bold border border-primary/10">{{
              badge }}</span>
            {% endfor %}
          </div>
          {% endif %}

          <a class="inline-flex items-center gap-2 text-primary font-bold group/link" href="{{ service.linkUrl }}">
            {{ service.linkText }}
            {{ icon('arrow_forward' , 'group-hover/link:translate-x-1 transition-transform') }}
          </a>
        </div>
      </section>
      {% endfor %}
    </div>
    <div class="flex items-center justify-center gap-4 mt-14 reveal reveal-up duration-1000 delay-700">

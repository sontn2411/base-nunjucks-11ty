<section id="gallery" class="relative py-24 md:py-32 bg-[#F5EFE0] overflow-hidden">
  <div class="absolute -top-8 -left-8 opacity-[0.04]"><svg width="200" height="200" viewBox="0 0 200 200">
      <path d="M0 200C0 200 50 150 80 80C110 10 200 0 200 0" stroke="#e11d48" stroke-width="1.5" fill="none"></path>
      <path d="M0 200C0 200 70 160 100 100C130 40 200 30 200 30" stroke="#e11d48" stroke-width="1" fill="none"></path>
      <path d="M0 200C0 200 90 170 120 120C150 70 200 60 200 60" stroke="#e11d48" stroke-width="0.8" fill="none"></path>
    </svg></div>
  <div class="absolute bottom-12 right-12 opacity-[0.05]"><svg width="100" height="100" viewBox="0 0 100 100">
      <circle cx="50" cy="50" r="45" stroke="#e11d48" stroke-width="0.5" fill="none"></circle>
      <circle cx="50" cy="50" r="35" stroke="#e11d48" stroke-width="0.5" fill="none"></circle>
      <circle cx="50" cy="50" r="25" stroke="#e11d48" stroke-width="0.5" fill="none"></circle>
      <circle cx="50" cy="50" r="15" stroke="#e11d48" stroke-width="0.5" fill="none"></circle>
      <circle cx="50" cy="50" r="3" fill="#e11d48"></circle>
    </svg></div>
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="text-center mb-16 reveal reveal-up">
      <div class="flex items-center justify-center gap-3 mb-6"><span
          class="block w-10 h-[1px] bg-gradient-to-r from-transparent to-primary"></span><svg width="20" height="20"
          viewBox="0 0 20 20" class="text-primary">
          <path d="M10 0L12 8L20 10L12 12L10 20L8 12L0 10L8 8Z" fill="currentColor" opacity="0.5"></path>
        </svg><span class="text-primary text-xs uppercase tracking-[0.3em] font-medium">Thư viện ảnh</span><svg
          width="20" height="20" viewBox="0 0 20 20" class="text-primary">
          <path d="M10 0L12 8L20 10L12 12L10 20L8 12L0 10L8 8Z" fill="currentColor" opacity="0.5"></path>
        </svg><span class="block w-10 h-[1px] bg-gradient-to-l from-transparent to-primary"></span></div>
      <h2
        class="font-['Playfair_Display',serif] text-3xl md:text-4xl lg:text-5xl font-bold text-[#1B3A4B] leading-tight mb-4">
        Khoảnh khắc <span class="text-prto-primary italic font-normal">tuyệt đẹp</span></h2>
      <div class="flex justify-center mt-3 mb-4"><svg width="80" height="8" viewBox="0 0 80 8" class="text-primary/40">
          <path d="M0 4C7 4 7 1 14 1C21 1 21 7 28 7C35 7 35 1 42 1C49 1 49 7 56 7C63 7 63 1 70 1C77 1 77 4 80 4"
            stroke="currentColor" stroke-width="1" fill="none"></path>
        </svg></div>
      <p class="text-[#7A8B99] text-base max-w-2xl mx-auto">Khám phá vẻ đẹp của Mövenpick Resort Cam Ranh qua bộ sưu tập
        hình ảnh</p>
    </div>
    {% set galleryItems = [
    {
    src: "./assets/images/gallery1.jpg",
    alt: "Resort toàn cảnh",
    span: "col-span-2 row-span-2",
    delay: "100ms"
    },
    {
    src:
    "./assets/images/gallery2.jpg",
    alt: "Hồ bơi vô cực",
    span: "col-span-1 row-span-1",
    delay: "180ms"
    },
    {
    src:
    "./assets/images/gallery3.jpg",
    alt: "Spa & Wellness",
    span: "col-span-1 row-span-1",
    delay: "260ms"
    },
    {
    src:
    "./assets/images/gallery4.jpg",
    alt: "Nội thất Villa",
    span: "col-span-1 row-span-1",
    delay: "340ms"
    },
    {
    src:
    "./assets/images/gallery2.jpg",
    alt: "Nhà hàng",
    span: "col-span-1 row-span-1",
    delay: "420ms"
    },
    {
    src:
    "./assets/images/gallery3.jpg",
    alt: "Hoàng hôn biển",
    span: "col-span-2 row-span-1",
    delay: "500ms"
    }
    ] %}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 auto-rows-[200px] md:auto-rows-[250px]">
      {% for item in galleryItems %}
      <div class="{{ item.span }} relative overflow-hidden cursor-pointer group reveal reveal-up"
        style="transition-delay: {{ item.delay }};"><img src="{{ item.src }}" alt="{{ item.alt }}"
          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
        <div
          class="absolute inset-0 bg-[#0D1B2A]/0 group-hover:bg-[#0D1B2A]/40 transition-colors duration-300 flex items-center justify-center">
          <div class="opacity-0 group-hover:opacity-100 transition-all duration-300 text-center">
            <div class="relative inline-block px-6 py-3">
              <div class="absolute top-0 left-0 w-4 h-4 border-t border-l border-primary"></div>
              <div class="absolute top-0 right-0 w-4 h-4 border-t border-r border-primary"></div>
              <div class="absolute bottom-0 left-0 w-4 h-4 border-b border-l border-primary"></div>
              <div class="absolute bottom-0 right-0 w-4 h-4 border-b border-r border-primary"></div><span
                class="text-white text-sm font-medium uppercase tracking-wider">{{ item.alt }}</span>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
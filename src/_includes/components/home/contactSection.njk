<section id="contact" class="relative py-24 md:py-32 overflow-hidden">
  <div class="absolute inset-0"><img src="./assets/images/contact.jpg" alt="Beach background"
      class="w-full h-full object-cover">
    <div class="absolute inset-0 bg-[#0D1B2A]/90"></div>
  </div>
  <div class="absolute top-8 left-8 w-20 h-20 border-t border-l border-primary/20 z-10"></div>
  <div class="absolute top-8 right-8 w-20 h-20 border-t border-r border-primary/20 z-10"></div>
  <div class="absolute bottom-8 left-8 w-20 h-20 border-b border-l border-primary/20 z-10"></div>
  <div class="absolute bottom-8 right-8 w-20 h-20 border-b border-r border-primary/20 z-10"></div>
  <div class="absolute top-1/4 right-1/4 animate-pulse opacity-15 z-10"><svg width="16" height="16" viewBox="0 0 16 16">
      <path d="M8 0L9.5 6.5L16 8L9.5 9.5L8 16L6.5 9.5L0 8L6.5 6.5Z" fill="#e11d48"></path>
    </svg></div>
  <div class="absolute bottom-1/3 left-1/4 animate-pulse opacity-10 z-10" style="animation-delay: 2s;"><svg width="12"
      height="12" viewBox="0 0 12 12">
      <path d="M6 0L7 5L12 6L7 7L6 12L5 7L0 6L5 5Z" fill="#e11d48"></path>
    </svg></div>
  <div class="relative max-w-7xl mx-auto px-6 md:px-12 z-10">
    <div class="text-center mb-16 reveal reveal-up">
      <div class="flex items-center justify-center gap-3 mb-6"><span
          class="block w-10 h-px bg-linear-to-r from-transparent to-primary"></span><svg width="20" height="20"
          viewBox="0 0 20 20" class="text-primary">
          <path d="M10 0L12 8L20 10L12 12L10 20L8 12L0 10L8 8Z" fill="currentColor" opacity="0.5"></path>
        </svg><span class="text-primary text-xs uppercase tracking-[0.3em] font-medium">Liên hệ</span><svg width="20"
          height="20" viewBox="0 0 20 20" class="text-primary">
          <path d="M10 0L12 8L20 10L12 12L10 20L8 12L0 10L8 8Z" fill="currentColor" opacity="0.5"></path>
        </svg><span class="block w-10 h-px bg-linear-to-l from-transparent to-primary"></span></div>
      <h2
        class="font-['Playfair_Display',serif] text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-4">
        Liên hệ <span class="text-primary italic font-normal">với chúng tôi</span></h2>
      <div class="flex justify-center mt-3 mb-4"><svg width="80" height="8" viewBox="0 0 80 8" class="text-primary/40">
          <path d="M0 4C7 4 7 1 14 1C21 1 21 7 28 7C35 7 35 1 42 1C49 1 49 7 56 7C63 7 63 1 70 1C77 1 77 4 80 4"
            stroke="currentColor" stroke-width="1" fill="none"></path>
        </svg></div>
      <p class="text-white/60 text-base max-w-2xl mx-auto">Hãy để lại thông tin, đội ngũ tư vấn sẽ liên hệ bạn trong
        thời gian sớm nhất</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <div class="reveal reveal-left">
        <form class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div><label class="text-white/60 text-xs uppercase tracking-wider mb-2 block">Họ và tên</label><input
                type="text"
                class="w-full bg-transparent border-b border-white/20 text-white py-3 focus:border-primary outline-none transition-colors placeholder:text-white/30"
                placeholder="Nguyễn Văn A" required="" value=""></div>
            <div><label class="text-white/60 text-xs uppercase tracking-wider mb-2 block">Số điện thoại</label><input
                type="tel"
                class="w-full bg-transparent border-b border-white/20 text-white py-3 focus:border-primary outline-none transition-colors placeholder:text-white/30"
                placeholder="0901 234 567" required="" value=""></div>
          </div>
          <div><label class="text-white/60 text-xs uppercase tracking-wider mb-2 block">Email</label><input type="email"
              class="w-full bg-transparent border-b border-white/20 text-white py-3 focus:border-primary outline-none transition-colors placeholder:text-white/30"
              placeholder="email@example.com" required="" value=""></div>
          <div><label class="text-white/60 text-xs uppercase tracking-wider mb-2 block">Lời nhắn</label><textarea
              rows="4"
              class="w-full bg-transparent border-b border-white/20 text-white py-3 focus:border-primary outline-none transition-colors placeholder:text-white/30 resize-none"
              placeholder="Tôi muốn tìm hiểu thêm về..."></textarea></div><button type="submit"
            class="relative bg-primary text-white text-sm font-semibold uppercase tracking-[0.15em] px-10 py-4 hover:bg-[#B8944F] transition-colors duration-300 w-full sm:w-auto group overflow-hidden"><span
              class="relative z-10">Gửi yêu cầu</span>
            <div
              class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 bg-linear-to-r from-transparent via-white/20 to-transparent">
            </div>
          </button>
        </form>
      </div>
      <div class="reveal reveal-right">
        <div class="space-y-8">
          <div class="flex items-start gap-4 group">
            <div class="relative w-12 h-12 flex items-center justify-center flex-shrink-0">
              <div
                class="absolute inset-0 border border-primary/50 rotate-45 group-hover:rotate-[135deg] transition-transform duration-500">
              </div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="lucide lucide-map-pin w-5 h-5 text-primary relative z-10">
                <path
                  d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0">
                </path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div><span class="text-white/50 text-xs uppercase tracking-wider block mb-1">Địa chỉ</span><span
                class="text-white text-base">Bãi Dài, Cam Ranh, Khánh Hòa, Việt Nam</span></div>
          </div>
          <div class="flex items-start gap-4 group">
            <div class="relative w-12 h-12 flex items-center justify-center flex-shrink-0">
              <div
                class="absolute inset-0 border border-primary/50 rotate-45 group-hover:rotate-[135deg] transition-transform duration-500">
              </div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="lucide lucide-phone w-5 h-5 text-primary relative z-10">
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z">
                </path>
              </svg>
            </div>
            <div><span class="text-white/50 text-xs uppercase tracking-wider block mb-1">Hotline</span><span
                class="text-white text-base">+84 258 399 8888</span></div>
          </div>
          <div class="flex items-start gap-4 group">
            <div class="relative w-12 h-12 flex items-center justify-center flex-shrink-0">
              <div
                class="absolute inset-0 border border-primary/50 rotate-45 group-hover:rotate-[135deg] transition-transform duration-500">
              </div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="lucide lucide-mail w-5 h-5 text-primary relative z-10">
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            </div>
            <div><span class="text-white/50 text-xs uppercase tracking-wider block mb-1">Email</span><span
                class="text-white text-base">info@movenpick-camranh.com</span></div>
          </div>
          <div class="flex items-start gap-4 group">
            <div class="relative w-12 h-12 flex items-center justify-center flex-shrink-0">
              <div
                class="absolute inset-0 border border-primary/50 rotate-45 group-hover:rotate-[135deg] transition-transform duration-500">
              </div><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="lucide lucide-clock w-5 h-5 text-primary relative z-10">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <div><span class="text-white/50 text-xs uppercase tracking-wider block mb-1">Giờ làm việc</span><span
                class="text-white text-base">24/7 — Luôn sẵn sàng</span></div>
          </div>
        </div>
        <div class="mt-10 h-48 bg-white/5 border border-white/10 overflow-hidden relative">
          <div class="absolute top-0 left-0 w-6 h-6 border-t border-l border-primary/40 z-10"></div>
          <div class="absolute top-0 right-0 w-6 h-6 border-t border-r border-primary/40 z-10"></div>
          <div class="absolute bottom-0 left-0 w-6 h-6 border-b border-l border-primary/40 z-10"></div>
          <div class="absolute bottom-0 right-0 w-6 h-6 border-b border-r border-primary/40 z-10"></div><iframe
            title="Movenpick Cam Ranh Location"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3906.0!2d109.1!3d11.95!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTHCsDU3JzAwLjAiTiAxMDnCsDA2JzAwLjAiRQ!5e0!3m2!1svi!2svn!4v1"
            width="100%" height="100%" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            style="border: 0px;"></iframe>
        </div>
      </div>
    </div>
  </div>
</section>